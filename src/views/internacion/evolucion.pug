extends ../layout

block content
  // contenedor principal
  .container.mt-4
    // mensajes de éxito y error
    if successMessage
      .alert.alert-success.alert-dismissible.fade.show
        button.btn-close(type="button" data-bs-dismiss="alert")
        = successMessage
    if errorMessage
      .alert.alert-danger.alert-dismissible.fade.show
        button.btn-close(type="button" data-bs-dismiss="alert")
        = errorMessage
    .row
      // cabecera con datos del paciente internado
      .col-12.mb-4
        // tarjeta de datos del paciente
        .card.bg-light
          .card-body.d-flex.justify-content-between.align-items-center
            // seccion izquierda: datos personales
            div
              // nombre del paciente
              h3= internacion.paciente_apellido + ', ' + internacion.paciente_nombre
              // ubicacion del paciente
              p.text-muted Ala: #{internacion.nombre_ala} | Hab: #{internacion.numero_hab} | Cama: #{internacion.nombre_cama}
              // badge de estado de alta
              if internacion.autorizado_alta_medica
                span.badge.bg-success Alta Medica Autorizada
            
            // seccion derecha: botones de accion
            div
              // boton para autorizar alta (solo medicos)
              if !internacion.autorizado_alta_medica && user && user.rol === 'medico'
                button.btn.btn-warning(onclick="showConfirmAltaModal()") 
                  i.bi.bi-check2-circle
                  |  Autorizar Alta Medica
              // boton para finalizar internacion (solo admision)
              if internacion.autorizado_alta_medica && user && user.rol === 'admision_internacion'
                button.btn.btn-danger(type="button" onclick="showConfirmFinalizarModal()")
                  i.bi.bi-box-arrow-right
                  |  Finalizar y Liberar Cama

      // columna izquierda con historial
      .col-md-7
        // titulo del historial
        h5 Historial de Seguimiento
        // itero sobre evoluciones
        each evo in evoluciones
          // tarjeta de evolucion
          .card.mb-3.border-start.border-info.border-4
            // cuerpo de tarjeta
            .card-body
              // fecha y medico
              .d-flex.justify-content-between.align-items-center.mb-2
                // fecha de evolucion
                h6.card-title.text-primary.mb-0= evo.fecha_formateada
                // nombre del medico
                small.text-muted
                  i.bi.bi-person-badge
                  |  #{evo.medico_nombre}
              // texto de evolucion
              p.card-text= evo.evolucion_clinica
              // separador
              hr
              // tratamiento actual
              small.text-muted Tratamiento: #{evo.tratamiento_actual}

      // columna derecha con formulario
      .col-md-5
        // formulario solo si no tiene alta y es medico
        if !internacion.autorizado_alta_medica && user && user.rol === 'medico'
          // tarjeta con formulario
          .card.shadow-sm
            // encabezado del formulario
            .card-header.bg-info.text-white Nueva Entrada de Piso
            // cuerpo del formulario
            .card-body
              // formulario que envia datos
              form(action=`/internacion/evolucion/${internacion.id_internacion}` method="POST")
                // campo evolucion clinica
                .mb-3
                  label.form-label Evolucion Clinica
                  textarea.form-control(name="evolucion" rows="4" required)
                // campo tratamiento
                .mb-3
                  label.form-label Tratamiento / Medicacion
                  textarea.form-control(name="tratamiento" rows="3")
                // boton guardar
                button.btn.btn-info.w-100(type="submit") Guardar Evolucion

  // contenedor de alertas emergentes
  #bootstrapAlertWrapper.position-fixed.top-50.start-50.translate-middle.p-3(style="z-index: 1080; display: none; min-width: 280px; max-width: 420px; width: 90%;")
    // alerta personalizada
    .alert.alert-success.alert-dismissible.fade.show.text-center(role="alert" id="bootstrapAlert")
      span#bootstrapAlertText
      button.btn-close(type="button" aria-label="Close" onclick="hideBootstrapAlert()")

  // modal de confirmacion para autorizar alta
  #confirmAltaModal.modal.fade(tabindex="-1" aria-labelledby="confirmAltaModalLabel" aria-hidden="true")
    .modal-dialog.modal-dialog-centered
      .modal-content
        // encabezado del modal
        .modal-header
          h5.modal-title#confirmAltaModalLabel Autorizar Alta Medica
          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
        // cuerpo del modal
        .modal-body
          p Confirmar autorizacion de alta medica?
        // pie del modal
        .modal-footer
          button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
          button.btn.btn-warning(type="button" id="confirmAltaButton") Confirmar

  form#confirmAltaForm(action=`/internacion/autorizar-alta/${internacion.id_internacion}` method="POST" style="display:none")

  // modal de confirmacion para finalizar internacion
  #confirmFinalizarModal.modal.fade(tabindex="-1" aria-labelledby="confirmFinalizarModalLabel" aria-hidden="true")
    .modal-dialog.modal-dialog-centered
      .modal-content
        // encabezado del modal
        .modal-header
          h5.modal-title#confirmFinalizarModalLabel Finalizar Internacion
          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
        // cuerpo del modal
        .modal-body
          p Confirma que el paciente se retira y se libera la cama?
        // pie del modal
        .modal-footer
          button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
          button.btn.btn-danger(type="button" id="confirmFinalizarButton") Confirmar

  // script para manejar modales y alertas
  script.
    // funcion para mostrar alerta
    function showBootstrapAlert(message, type = 'success') {
      const wrapper = document.getElementById('bootstrapAlertWrapper');
      const alert = document.getElementById('bootstrapAlert');
      const alertText = document.getElementById('bootstrapAlertText');

      alert.className = `alert alert-${type} alert-dismissible fade show text-center`;
      alertText.textContent = message;
      wrapper.style.display = 'block';
    }

    // funcion para ocultar alerta
    function hideBootstrapAlert() {
      const wrapper = document.getElementById('bootstrapAlertWrapper');
      if (wrapper) {
        wrapper.style.display = 'none';
      }
    }

    // referencias globales de modales
    let confirmAltaModal, confirmFinalizarModal;

    // funcion para mostrar modal de alta
    function showConfirmAltaModal() {
      if (confirmAltaModal) {
        confirmAltaModal.show();
      }
    }

    // funcion para mostrar modal de finalizacion
    function showConfirmFinalizarModal() {
      if (confirmFinalizarModal) {
        confirmFinalizarModal.show();
      }
    }

    // evento cuando carga el dom
    document.addEventListener('DOMContentLoaded', function() {
      // inicializo modales
      confirmAltaModal = new bootstrap.Modal(document.getElementById('confirmAltaModal'));
      confirmFinalizarModal = new bootstrap.Modal(document.getElementById('confirmFinalizarModal'));

      // obtengo referencias a botones
      const confirmAltaButton = document.getElementById('confirmAltaButton');
      const confirmFinalizarButton = document.getElementById('confirmFinalizarButton');

      // evento click boton confirmar alta
      if (confirmAltaButton) {
        confirmAltaButton.addEventListener('click', function() {
          const form = document.getElementById('confirmAltaForm');
          if (form) {
            confirmAltaModal.hide();
            form.submit();
          }
        });
      }

      // evento click boton confirmar finalizacion
      if (confirmFinalizarButton) {
        confirmFinalizarButton.addEventListener('click', function() {
          // creo formulario para enviar datos
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/internacion/finalizar';

          // agrego id de internacion
          const inputInternacion = document.createElement('input');
          inputInternacion.type = 'hidden';
          inputInternacion.name = 'idInternacion';
          inputInternacion.value = #{internacion.id_internacion};

          // agrego id de cama
          const inputCama = document.createElement('input');
          inputCama.type = 'hidden';
          inputCama.name = 'idCama';
          inputCama.value = #{internacion.cama_id};

          form.appendChild(inputInternacion);
          form.appendChild(inputCama);
          document.body.appendChild(form);
          // oculto modal y envio formulario
          confirmFinalizarModal.hide();
          form.submit();
        });
      }
    });