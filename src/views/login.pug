extends layout

block content
  // --- contenedor de login centrado ---
  .row.justify-content-center.align-items-center(style="min-height: 70vh;")
    .col-md-6.col-lg-5
     
      // marco principal del formulario de acceso
      .card.border-0.shadow-lg
        .card-header.bg-primary.py-4
          h5.card-title.mb-0.text-white.text-center
            i.bi.bi-lock.me-2
            | Acceso al Sistema

        .card-body.p-5
          

          form(action="/login", method="POST", id="loginForm")
            // campo usuario/email
            .mb-4
              label.form-label.fw-bold.text-dark(for="usuario") 
                i.bi.bi-person.me-2
                | Usuario o Email
              .input-group.input-group-lg
                span.input-group-text.bg-light
                  i.bi.bi-person-circle
                input#usuario.form-control(
                  type="text", 
                  name="usuario", 
                  placeholder="Ingrese su usuario o email", 
                  required, 
                  autofocus
                )

            // campo contrasena
            .mb-4
              label.form-label.fw-bold.text-dark(for="password")
                i.bi.bi-key.me-2
                | Contraseña
              .input-group.input-group-lg
                span.input-group-text.bg-light
                  i.bi.bi-lock
                input#password.form-control(
                  type="password", 
                  name="password", 
                  placeholder="Ingrese su contraseña", 
                  required
                )

            // opcion recordar credenciales
            .form-check.mb-4
              input.form-check-input#recordar(type="checkbox", name="recordar")
              label.form-check-label.text-muted(for="recordar")
                | Recordar mis credenciales

            // boton enviar formulario
            .d-grid.gap-2.mb-3
              button.btn.btn-primary.btn-lg.fw-bold(type="submit")
                i.bi.bi-arrow-right-circle.me-2
                | Ingresar al Sistema

            // enlace para recuperar contraseña
            .text-center
              small.text-muted
                a.text-decoration-none.text-primary(href="#" id="forgotPasswordLink") 
                  | ¿Olvidó su contraseña?

        .card-footer.bg-light.text-center.py-3.border-top
          small.text-muted
            i.bi.bi-info-circle.me-1
            | Sistema seguro - Acceso restringido
            br
            | Diseñado por Julian Rios © 2026

  // toast error de login
  if error
    .toast-container.position-fixed.bottom-0.end-0.p-3
      #toastError.toast.show.bg-danger.text-white(role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="false")
        .toast-header.bg-danger.text-white
          i.bi.bi-exclamation-triangle-fill.me-2
          strong.me-auto La Trinidad HIS
          small Error
          button.btn-close.btn-close-white(type="button" data-bs-dismiss="toast" aria-label="Close")
        .toast-body
          p.mb-0
            strong 
              i.bi.bi-x-circle.me-1
              | #{error}

  // toast de olvido de contraseña
  .toast-container.position-fixed.bottom-0.end-0.p-3
    #toastForgotPassword.toast.bg-info.text-white(role="alert" aria-live="assertive" aria-atomic="true")
      .toast-header.bg-info.text-white
        i.bi.bi-info-circle-fill.me-2
        strong.me-auto Hospital La Trinidad 
        small Información
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="toast" aria-label="Close")
      .toast-body
        p.mb-2
          strong 
            i.bi.bi-envelope.me-1
            | Comuníquese con el administrador del sistema:
        if adminData
          p.mb-1
            strong #{adminData.nombre} #{adminData.apellido}
          if adminData.telefono
            p.mb-1
              i.bi.bi-telephone.me-2
              | Teléfono: #{adminData.telefono}
          if adminData.email
            p.mb-0
              i.bi.bi-envelope-at.me-2
              | Email: #{adminData.email}
        else
          p.mb-0.text-warning
            i.bi.bi-exclamation-triangle.me-1
            | No se pudo obtener la informacion del administrador

  script.
    // activo el foco en el campo usuario
    document.getElementById('usuario').focus();

    // valido los campos antes de enviar
    document.getElementById('loginForm').addEventListener('submit', function(e) {
      const usuario = document.getElementById('usuario').value.trim();
      const password = document.getElementById('password').value;

      if (!usuario) {
        e.preventDefault();
        alert('Por favor ingrese su usuario o email');
        return;
      }

      if (!password) {
        e.preventDefault();
        alert('Por favor ingrese su contraseña');
        return;
      }
    });

    // capturo clic en el enlace de recuperar contraseña
    document.getElementById('forgotPasswordLink').addEventListener('click', function(e) {
      e.preventDefault();
      
      // muestro el toast con retardo personalizado
      const toastElement = document.getElementById('toastForgotPassword');
      const toast = new bootstrap.Toast(toastElement, {
        autohide: true,
        delay: 10000  // 10 segundos
      });
      toast.show();
    });
