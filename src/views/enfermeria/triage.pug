extends ../layout

block content
  h4.mb-4 
    i.bi.bi-heart-pulse-fill.text-danger.me-2
    | Panel de Triage (Enfermería)

  .row
    // Lista de espera a la izquierda
    .col-md-4
      .card.border-0.shadow-sm
        .card-header.bg-white.fw-bold 
          i.bi.bi-people.me-2
          | Pacientes en Espera
        .list-group.list-group-flush.overflow-auto(style="max-height: 70vh;")
          each paciente in listaEspera
            a.list-group-item.list-group-item-action.py-3(href=`/triage/${paciente.id_admision}`)
              .d-flex.w-100.justify-content-between.align-items-center.mb-1
                h6.mb-0.fw-bold.text-primary= `${paciente.apellido}, ${paciente.nombre}`
                small.badge.bg-light.text-dark.border= paciente.hora_ingreso
              
              .mb-1
                small.text-muted
                  i.bi.bi-person-badge.me-1
                  | DNI: #{paciente.dni}
              
              // --- Nueva sección de síntomas declarados ---
              .mt-2.p-2.bg-light.rounded-1.border-start.border-3.border-info
                small.text-dark.d-block(style="font-style: italic;")
                  i.bi.bi-chat-left-text.me-1.text-info
                  strong Síntoma: 
                  span= paciente.motivo_consulta || 'No especificado'

    // Formulario de Triage a la derecha
    .col-md-8
      if seleccionado
        .card.border-0.shadow-sm
          .card-body
            .d-flex.justify-content-between.align-items-center
              h5.card-title.text-primary.mb-0 
                i.bi.bi-clipboard2-check.me-2
                | Atención: #{seleccionado.apellido}, #{seleccionado.nombre}
              
            hr
            form(action="/guardar-triage", method="POST")
              input(type="hidden", name="id_admision", value=seleccionado.id_admision)
              
              .row.g-3
                .col-md-6
                  label.form-label.fw-bold Clasificación de Riesgo
                  select.form-select.border-primary.triage-prioridad(name="prioridad", required)
                    option(value="" disabled selected) Seleccione nivel...
                    option(value="1" class="triage-option-1") Nivel 1 - Emergencia (Riesgo Vital)
                    option(value="2" class="triage-option-2") Nivel 2 - Muy Urgente
                    option(value="3" class="triage-option-3") Nivel 3 - Urgente
                    option(value="4" class="triage-option-4") Nivel 4 - Menos Urgente
                    option(value="5" class="triage-option-5") Nivel 5 - No Urgente
                
                .col-md-3
                  label.form-label.fw-bold Presión Art.
                  input.form-control(type="text", name="presion", placeholder="120/80", maxlength="7")
                .col-md-3
                  label.form-label.fw-bold Temp. (°C)
                  input.form-control(type="number", step="0.1", name="temperatura", min="35", max="42", placeholder="36.5")
                
                .col-md-4
                  label.form-label.fw-bold Frec. Cardíaca (LPM)
                  input.form-control(type="number", name="frecuencia", min="40", max="200", placeholder="Ej: 80")
                .col-md-4
                  label.form-label.fw-bold Sat. Oxígeno (%)
                  input.form-control(type="number", name="saturacion", min="0", max="100", placeholder="Ej: 98")
                
                .col-12
                  label.form-label.fw-bold Observaciones de Enfermería (Triage)
                  textarea.form-control(name="observaciones", rows="3", placeholder="Detalles observados durante la toma de signos...")

              button.btn.btn-primary.mt-4.w-100.py-2(type="submit") 
                i.bi.bi-send-check.me-2
                | Finalizar Triage y Enviar a Médico
      else
        .text-center.py-5.text-muted.bg-white.rounded.shadow-sm
          i.bi.bi-arrow-left-circle.display-1.text-light
          p.mt-3.fs-5 Seleccione un paciente de la lista para iniciar el triage.

  script.
    document.addEventListener('DOMContentLoaded', function() {
      const presionInput = document.querySelector('input[name="presion"]');
      if (!presionInput) return;

      presionInput.addEventListener('input', function() {
        let digits = this.value.replace(/\D/g, '');
        if (digits.length > 3) {
          digits = digits.slice(0, 3) + '/' + digits.slice(3, 5);
        }
        this.value = digits;
      });

      // Aplicar colores a las opciones del select de triage
      const prioridadSelect = document.querySelector('select[name="prioridad"]');
      if (prioridadSelect) {
        const triageColors = {
          '1': '#dc3545', // Rojo - Emergencia
          '2': '#fd7e14', // Naranja - Muy Urgente
          '3': '#ffc107', // Amarillo - Urgente
          '4': '#198754', // Verde - Menos Urgente
          '5': '#0dcaf0'  // Azul - No Urgente
        };

        function updateSelectColor() {
          const selectedValue = prioridadSelect.value;
          if (selectedValue && triageColors[selectedValue]) {
            prioridadSelect.style.color = triageColors[selectedValue];
            prioridadSelect.style.fontWeight = '700';
          } else {
            prioridadSelect.style.color = '#0d6efd'; // Color por defecto
            prioridadSelect.style.fontWeight = 'normal';
          }
        }

        prioridadSelect.addEventListener('change', updateSelectColor);
        updateSelectColor(); // Aplicar color inicial si hay selección
      }

      // Validación de rangos
      const formulario = document.querySelector('form');
      if (formulario) {
        formulario.addEventListener('submit', function(e) {
          const temp = document.querySelector('input[name="temperatura"]').value;
          const freq = document.querySelector('input[name="frecuencia"]').value;
          const sat = document.querySelector('input[name="saturacion"]').value;

          // Validar temperatura
          if (temp && (parseFloat(temp) < 35 || parseFloat(temp) > 42)) {
            e.preventDefault();
            alert('⚠️ Temperatura fuera de rango.\nRango válido: 35°C - 42°C');
            return;
          }

          // Validar frecuencia cardíaca
          if (freq && (parseInt(freq) < 40 || parseInt(freq) > 200)) {
            e.preventDefault();
            alert('⚠️ Frecuencia cardíaca fuera de rango.\nRango válido: 40 - 200 LPM');
            return;
          }

          // Validar saturación
          if (sat && (parseInt(sat) < 0 || parseInt(sat) > 100)) {
            e.preventDefault();
            alert('⚠️ Saturación de oxígeno fuera de rango.\nRango válido: 0% - 100%');
            return;
          }
        });
      }
    });