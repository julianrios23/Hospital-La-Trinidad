extends layout

block content
  .container.mt-5
    .row.justify-content-center
      .col-md-6
        .card.shadow-lg.border-0
          .card-header.bg-primary.text-white
            h4.mb-0
              i.bi.bi-key.me-2
              | Cambiar Contraseña

          .card-body.p-4
            // Mensaje de error
            if error
              .alert.alert-danger.alert-dismissible.fade.show(role="alert")
                i.bi.bi-exclamation-triangle.me-2
                strong Error:
                | #{error}
                button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

            // Mensaje de éxito
            if exito
              .alert.alert-success.alert-dismissible.fade.show(role="alert")
                i.bi.bi-check-circle.me-2
                strong ¡Éxito!
                | #{exito}
                button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

            form(method="POST" action="/cambiar-password" id="cambiarPasswordForm")
              // Contraseña Actual
              .mb-3
                label.form-label.fw-bold(for="passwordActual")
                  i.bi.bi-lock.me-2
                  | Contraseña Actual
                input#passwordActual.form-control(
                  type="password"
                  name="passwordActual"
                  placeholder="Ingrese su contraseña actual"
                  required
                )
                small.text-muted
                  | Este campo es obligatorio para confirmar su identidad

              // Contraseña Nueva
              .mb-3
                label.form-label.fw-bold(for="passwordNueva")
                  i.bi.bi-shield-lock.me-2
                  | Contraseña Nueva
                input#passwordNueva.form-control(
                  type="password"
                  name="passwordNueva"
                  placeholder="Ingrese su nueva contraseña"
                  minlength="6"
                  required
                )
                small.text-muted
                  | Mínimo 6 caracteres

              // Confirmar Contraseña Nueva
              .mb-4
                label.form-label.fw-bold(for="passwordConfirmar")
                  i.bi.bi-shield-lock.me-2
                  | Confirmar Contraseña
                input#passwordConfirmar.form-control(
                  type="password"
                  name="passwordConfirmar"
                  placeholder="Confirme su nueva contraseña"
                  minlength="6"
                  required
                )
                small.text-muted.d-block.mt-2
                  i.bi.bi-info-circle.me-1
                  | Las contraseñas deben coincidir

              // Botones
              .d-grid.gap-2
                button.btn.btn-primary.btn-lg(type="submit")
                  i.bi.bi-check-circle.me-2
                  | Actualizar Contraseña
                a.btn.btn-secondary.btn-lg(href="javascript:history.back()")
                  i.bi.bi-arrow-left.me-2
                  | Cancelar

            // Información de seguridad
            .mt-4.pt-3.border-top
              .alert.alert-info.mb-0
                i.bi.bi-shield-check.me-2
                strong Recomendaciones de seguridad:
                ul.mb-0.mt-2
                  li Usa una contraseña única que no uses en otros sitios
                  li Combina letras mayúsculas, minúsculas, números y caracteres especiales
                  li No compartas tu contraseña con nadie
                  li Cambia tu contraseña regularmente

  // Validaciones en el cliente
  script.
    const form = document.getElementById('cambiarPasswordForm');
    form.addEventListener('submit', function(e) {
      const passwordNueva = document.getElementById('passwordNueva').value;
      const passwordConfirmar = document.getElementById('passwordConfirmar').value;
      const passwordActual = document.getElementById('passwordActual').value;

      if (passwordNueva !== passwordConfirmar) {
        e.preventDefault();
        alert('Las contraseñas nuevas no coinciden');
        return;
      }

      if (passwordNueva.length < 6) {
        e.preventDefault();
        alert('La contraseña debe tener al menos 6 caracteres');
        return;
      }

      if (passwordActual === passwordNueva) {
        e.preventDefault();
        alert('La contraseña nueva debe ser diferente a la actual');
        return;
      }
    });
