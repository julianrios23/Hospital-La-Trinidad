extends ../layout

block content
  h4.mb-4
    i.bi.bi-person-fill-edit.text-primary.me-2
    | Editar Paciente

  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-white.fw-bold.d-flex.justify-content-between.align-items-center
          span
            i.bi.bi-pencil.me-2
            | Información del Paciente
          a.btn.btn-secondary.btn-sm(href="/lista-pacientes")
            i.bi.bi-arrow-left.me-2
            | Volver a la Lista

        .card-body
          form(action=`/pacientes/${paciente.id_paciente}/actualizar`, method="POST")
            .row
              .col-md-6.mb-3
                label.form-label.fw-bold(for="dni") DNI
                input.form-control(type="text", id="dni", name="dni", value=paciente.dni, readonly)
              .col-md-6.mb-3
                label.form-label.fw-bold(for="apellido") Apellido
                input.form-control(type="text", id="apellido", name="apellido", value=paciente.apellido, readonly)
            .row
              .col-md-6.mb-3
                label.form-label.fw-bold(for="nombre") Nombre
                input.form-control(type="text", id="nombre", name="nombre", value=paciente.nombre, readonly)
              .col-md-6.mb-3
                label.form-label.fw-bold(for="fecha_nacimiento") Fecha de Nacimiento
                input.form-control(type="date", id="fecha_nacimiento", name="fecha_nacimiento", value=paciente.fecha_nacimiento.toISOString().split('T')[0], readonly)
            .row
              .col-md-6.mb-3
                label.form-label.fw-bold(for="genero") Género
                input.form-control(type="text", id="genero", name="genero", value=paciente.genero, readonly)
              .col-md-6.mb-3
                label.form-label.fw-bold(for="edad") Edad
                input.form-control(type="text", id="edad", name="edad", value=paciente.edad, readonly)
            .row
              .col-md-6.mb-3
                label.form-label.fw-bold(for="obrasocial") Obra Social
                select.form-select(id="obrasocial", name="obrasocial", required)
                  each obra in obrasSociales
                    option(value=obra.id_obra_social, selected=(obra.id_obra_social == paciente.obrasocial))= obra.nombre_obra_social
              .col-md-6.mb-3
                label.form-label.fw-bold(for="telefono") Teléfono
                input.form-control(type="tel", id="telefono", name="telefono", value=paciente.telefono || '', placeholder="Ingrese teléfono")
            .row
              .col-12.mb-3
                label.form-label.fw-bold(for="direccion") Dirección
                input.form-control(type="text", id="direccion", name="direccion", value=paciente.direccion || '', placeholder="Ingrese dirección")
            .row
              .col-12
                .d-flex.gap-2
                  button.btn.btn-primary(type="submit")
                    i.bi.bi-check-circle.me-2
                    | Guardar Cambios
                  a.btn.btn-secondary(href="/lista-pacientes")
                    i.bi.bi-x-circle.me-2
                    | Cancelar