doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title 🏥 Hospital La Trinidad HIS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    link(rel="stylesheet", href="/css/style.css") 
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-primary.sticky-top
      .container
        a.navbar-brand(href="/") 🏥 Hospital La Trinidad
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
          span.navbar-toggler-icon
        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.ms-auto.align-items-center
            li.nav-item
              if user && user.rol !== 'enfermeria' && user.rol !== 'medico'
                a.nav-link(href="/")
                  i.bi.bi-person-vcard.me-1
                  | Admisión
              else
                span.nav-link.text-warning.disabled
                  i.bi.bi-person-vcard.me-1
                  | Admisión
            li.nav-item
              if user && user.rol !== 'admision_guardia' && user.rol !== 'medico'
                a.nav-link(href="/triage")
                  i.bi.bi-heart-pulse.me-1
                  | Enfermería Triage
              else
                span.nav-link.text-warning.disabled
                  i.bi.bi-heart-pulse.me-1
                  | Enfermería Triage
            li.nav-item
              if user && user.rol !== 'admision_guardia' && user.rol !== 'enfermeria'
                a.nav-link(href="/atencion-medica")
                  i.bi.bi-clipboard2-pulse.me-1
                  | Atención Médicos
              else
                span.nav-link.text-warning.disabled
                  i.bi.bi-clipboard2-pulse.me-1
                  | Atención Médicos
            if user && user.rol === 'administrador'
              li.nav-item
                a.nav-link(href="/admin/usuarios")
                  i.bi.bi-gear.me-1
                  | Administración
            if user
              li.nav-item.dropdown.ms-lg-3
                a.nav-link.dropdown-toggle(href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false")
                  i.bi.bi-person-circle.me-1
                  span= user.nombre
                ul.dropdown-menu.dropdown-menu-end(aria-labelledby="userDropdown")
                  li.dropdown-header
                    small.text-muted
                      | Rol: 
                      span.badge.bg-secondary= user.rol
                  li: hr.dropdown-divider
                  li
                    a.dropdown-item(href="/logout")
                      i.bi.bi-box-arrow-right.me-2
                      | Cerrar sesión
            else
              li.nav-item.ms-lg-3
                a.nav-link(href="/login")
                  i.bi.bi-box-arrow-in-right.me-1
                  | Iniciar sesión
            li.nav-item.ms-lg-3
              span.badge.bg-danger.p-2 
                i.bi.bi-activity.me-1
                | Guardia Activa

    .container.mt-4
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")