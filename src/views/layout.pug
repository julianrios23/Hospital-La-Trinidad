doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Clínica La Trinidad - Sistema de Guardia
    // Bootstrap CSS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    // Estilos personalizados
    style.
      body { background-color: #f8f9fa; }
      .navbar { background-color: #004a99; }
      .card-header { font-weight: bold; }
  body
    nav.navbar.navbar-expand-lg.navbar-dark.mb-4
      .container
        a.navbar-brand(href="/") 🏥 Clínica La Trinidad
        .navbar-nav
          a.nav-link(href="/") Ventanilla
          a.nav-link(href="/triage") Triage
          a.nav-link(href="/medico") Médicos

    .container
      block content

    // Bootstrap JS
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")