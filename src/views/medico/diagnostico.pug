extends ../layout

block content
  // titulo de la pagina
  h4.mb-4
    i.bi.bi-clipboard2-check.text-success.me-2
    | Atencion Medica - Diagnostico y Tratamiento

  // contenedor con dos columnas: datos y formulario
  .row
    // columna izquierda con datos del paciente
    .col-md-4
      // tarjeta con informacion del paciente
      .card.border-0.shadow-sm.mb-4
        // encabezado con titulo
        .card-header.bg-primary.text-white.fw-bold
          i.bi.bi-person.me-2
          | Datos del Paciente
        // cuerpo con datos detallados
        .card-body
          // nombre del paciente
          h5.card-title.text-primary= `${paciente.apellido}, ${paciente.nombre}`
          // datos personales del paciente
          p.card-text.mb-1
            strong DNI: 
            | #{paciente.dni}
          p.card-text.mb-1
            strong Edad: 
            | #{paciente.edad || 'No especificada'} anos
          p.card-text.mb-1
            strong Genero: 
            | #{paciente.genero}
          p.card-text.mb-1
            strong Obra Social: 
            | #{paciente.obra_social || 'No posee'}

      // tarjeta con datos de triage
      .card.border-0.shadow-sm.mb-4
        // encabezado con titulo
        .card-header.bg-warning.text-dark.fw-bold
          i.bi.bi-heart-pulse.me-2
          | Datos del Triage
        // cuerpo con signos vitales
        .card-body
          // nivel de prioridad
          .mb-2
            span.badge(class=`badge bg-${triage.prioridad == 1 ? 'danger' : triage.prioridad == 2 ? 'warning' : 'info'} fs-6`)
              | Nivel #{triage.prioridad} - Prioridad
          // grid con signos vitales
          .row.g-2
            .col-6
              small.text-muted.d-block Presion Arterial
              strong= triage.presion_arterial || 'No registrado'
            .col-6
              small.text-muted.d-block Temperatura
              strong= `${triage.temperatura || 'N/A'}C`
            .col-6
              small.text-muted.d-block Frecuencia Cardiaca
              strong= `${triage.frecuencia_cardiaca || 'N/A'} LPM`
            .col-6
              small.text-muted.d-block Saturacion O2
              strong= `${triage.saturacion_oxigeno || 'N/A'}%`
          // separador
          hr
          // observaciones de enfermeria
          small.text-muted.d-block Observaciones Enfermeria
          p.small= triage.observaciones_enfermeria || 'Sin observaciones'

    // columna derecha con formulario de diagnostico
    .col-md-8
      // tarjeta principal del formulario
      .card.border-0.shadow-sm
        // encabezado con titulo
        .card-header.bg-success.text-white.fw-bold
          i.bi.bi-stethoscope.me-2
          | Diagnostico y Tratamiento 
        // cuerpo del formulario
        .card-body
          // formulario que envia datos al servidor
          form(action="/guardar-diagnostico", method="POST")
            // id oculto de admision
            input(type="hidden", name="admision_id", value=admision_id)

            // campo para evolucion y diagnostico
            .mb-4
              label.form-label.fw-bold.h5.text-primary Evolucion y Diagnostico
              textarea.form-control(name="diagnostico", rows="4", placeholder="Describa la evolucion del paciente, sintomas actuales y diagnostico medico...", required)

            // fila con tratamiento e indicaciones
            .row
              // campo para tratamiento
              .col-md-6.mb-4
                label.form-label.fw-bold.h6.text-info Tratamiento / Medicacion Suministrada
                textarea.form-control(name="tratamiento_medicacion", rows="4", placeholder="Medicamentos administrados, dosis, via de administracion...")

              // campo para indicaciones
              .col-md-6.mb-4
                label.form-label.fw-bold.h6.text-warning Indicaciones 
                textarea.form-control(name="indicaciones_alta", rows="4", placeholder="Instrucciones para el paciente, controles futuros, recomendaciones...")

            // checkbox para solicitar internacion
            .form-check.form-switch.mb-4.p-3.bg-light.rounded
              input.form-check-input#requiere_internacion(type="checkbox", name="requiere_internacion", value="1")
              label.form-check-label.fw-bold.text-danger.fs-5(for="requiere_internacion")
                i.bi.bi-hospital.me-2
                | Requiere Internacion Hospitalaria

            // seccion de botones
            .d-flex.justify-content-between.align-items-center
              // boton para volver
              a.btn.btn-secondary(href="/atencion-medica")
                i.bi.bi-arrow-left.me-2
                | Volver a Lista
              // botones de guardar y finalizar
              .d-flex.gap-2
                button.btn.btn-outline-primary(type="button")
                  i.bi.bi-save.me-2
                  | Guardar Borrador
                // boton principal para finalizar
                button.btn.btn-success.btn-lg.px-4(type="submit", id="btnFinalizar")
                  i.bi.bi-check-circle.me-2
                  | Finalizar Atencion

  // notificacion al finalizar atencion
  .toast-container.position-fixed.top-50.start-50.p-3(style="transform: translate(-50%, -50%);")
    // toast de exito
    #toastFinAtension.toast.bg-success.text-white(role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000")
      // encabezado del toast
      .toast-header.bg-success.text-white
        i.bi.bi-check-circle-fill.me-2
        strong.me-auto La Trinidad HIS
        small Atencion Completada
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="toast" aria-label="Close")
      // cuerpo del toast
      .toast-body
        p.mb-1
          strong  Atencion medica finalizada exitosamente
        // contador de redireccion
        p.mb-0.text-white-50
          i.bi.bi-clock.me-1
          | Redirigiendo en 
          span#timerToast 5
          |  segundos...

  // script para mostrar toast y redirigir
  script.
    // evento click en boton finalizar
    document.getElementById('btnFinalizar').addEventListener('click', function(e) {
      e.preventDefault();
      
      // muestro el toast de exito
      const toastElement = document.getElementById('toastFinAtension');
      const toast = new bootstrap.Toast(toastElement);
      toast.show();
      
      // contador de 5 segundos
      let countdown = 5;
      const timerElement = document.getElementById('timerToast');
      
      // actualizo cada segundo
      const interval = setInterval(() => {
        countdown--;
        if (timerElement) timerElement.textContent = countdown;
        if (countdown <= 0) {
          clearInterval(interval);
          // envio el formulario despues de 5 segundos
          document.querySelector('form').submit();
        }
      }, 1000);
    });